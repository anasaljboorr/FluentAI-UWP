<Page
    x:Class="Project_FluentAI.Views.ChatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Project_FluentAI.Models"
    xmlns:helpers="using:Project_FluentAI.Helpers"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <helpers:UserToAlignmentConverter x:Key="UserToAlignmentConverter"/>
        <helpers:UserToBackgroundConverter x:Key="UserToBackgroundConverter"/>
        <helpers:UserToForegroundConverter x:Key="UserToForegroundConverter"/>

        <DataTemplate x:Key="MessageTemplate" x:DataType="models:Message">
            <!-- Grid with transparent background ensures the entire message row/area can catch right-clicks -->
            <Grid Margin="0,4,0,12" 
                  Background="Transparent"
                  HorizontalAlignment="{x:Bind IsUser, Converter={StaticResource UserToAlignmentConverter}}">
                <Grid.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="Copy Message"
                                        Icon="Copy"
                                        Click="CopyMessage_Click"/>
                        <MenuFlyoutSeparator/>
                        <MenuFlyoutItem Text="Delete Message"
                                        Icon="Delete"
                                        Click="DeleteMessage_Click"/>
                    </MenuFlyout>
                </Grid.ContextFlyout>
                <Border Background="{x:Bind IsUser, Converter={StaticResource UserToBackgroundConverter}}"
                        CornerRadius="4" Padding="12,8" MaxWidth="500">
                    <TextBlock Text="{x:Bind Content, Mode=OneWay}"
                               TextWrapping="Wrap"
                               Foreground="{x:Bind IsUser, Converter={StaticResource UserToForegroundConverter}}"/>
                </Border>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid x:Name="RootGrid" Padding="40,32,40,32">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="WideState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="641"/>
                    </VisualState.StateTriggers>
                </VisualState>
                <VisualState x:Name="NarrowState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0"/>
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="RootGrid.Padding" Value="16,20,16,20"/>
                        <Setter Target="ChatTitle.Margin" Value="0,0,0,16"/>
                        <Setter Target="ChatTitle.FontSize" Value="24"/>
                        <Setter Target="InputArea.Margin" Value="0,16,0,0"/>
                        <Setter Target="SendButton.Padding" Value="16,4,16,6"/>
                        <Setter Target="SendButton.Width" Value="70"/>
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="ChatTitle"
                   Text="Select a conversation"
                   FontSize="28"
                   FontWeight="Light"
                   Margin="0,0,0,32"/>

        <ListView Grid.Row="1" x:Name="MessageListView"
                  SelectionMode="None"
                  ItemTemplate="{StaticResource MessageTemplate}">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>

        <Grid x:Name="InputArea" Grid.Row="2" Margin="0,24,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Ask a question" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBox x:Name="InputBox"
                         PlaceholderText="Type your message here..."
                         AcceptsReturn="True"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Center"
                         KeyDown="InputBox_KeyDown"/>
            </StackPanel>

            <Button x:Name="SendButton"
                    Grid.Column="1"
                    Content="Send"
                    Style="{StaticResource AccentButtonStyle}"
                    Margin="12,0,0,0"
                    VerticalAlignment="Bottom"
                    Padding="24,4,24,6"
                    Click="SendButton_Click"
                    Background="{ThemeResource SystemControlHighlightAccentBrush}"
                    Height="32" Width="84"/>
        </Grid>
    </Grid>
</Page>
