<Page
    x:Class="Project_FluentAI.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid x:Name="RootGrid" Padding="40,32,40,32">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="WideState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="641"/>
                    </VisualState.StateTriggers>
                </VisualState>
                <VisualState x:Name="NarrowState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0"/>
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="RootGrid.Padding" Value="16,24,16,24"/>
                        <Setter Target="SettingsHeader.Margin" Value="0,0,0,16"/>
                        <Setter Target="SettingsHeader.FontSize" Value="24"/>
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="SettingsHeader" 
                   Text="Settings" 
                   FontSize="28"
                   FontWeight="Light"
                   Margin="0,0,0,32"/>

        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="32">
                <!-- Personalization Section -->
                <StackPanel>
                    <TextBlock Text="Personalization" 
                               Style="{StaticResource SubtitleTextBlockStyle}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12"/>
                    <TextBlock Text="Change how FluentAI looks and feels on your device." 
                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                               Margin="0,0,0,16"/>
                    <ComboBox x:Name="ThemeSelector" Header="App Theme" Width="200" SelectedIndex="1" SelectionChanged="ThemeSelector_SelectionChanged">
                        <ComboBoxItem Content="Light"/>
                        <ComboBoxItem Content="Dark"/>
                        <ComboBoxItem Content="Use System Setting"/>
                    </ComboBox>
                </StackPanel>

                <Rectangle Height="1" Fill="{ThemeResource SystemControlBackgroundBaseLowBrush}"/>

                <!-- AI Models Section -->
                <StackPanel>
                    <TextBlock Text="AI Models" 
                               Style="{StaticResource SubtitleTextBlockStyle}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12"/>
                    <TextBlock Text="Configure your preferred AI providers and models." 
                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                               Margin="0,0,0,16"/>
<ToggleSwitch x:Name="LocalModelsToggle" Header="Use Local Models (Ollama)" IsOn="False" Toggled="LocalModelsToggle_Toggled"/>
                    <TextBox x:Name="OllamaModelBox" Header="Ollama Model Name" PlaceholderText="qwen3:8b" Width="239" HorizontalAlignment="Left" Margin="0,12,0,0" TextChanged="OllamaModelBox_TextChanged"/>
                    <PasswordBox x:Name="ApiKeyBox" Header="OpenAI API Key" PlaceholderText="sk-..." Width="239" HorizontalAlignment="Left" Margin="0,12,0,0" PasswordChanged="ApiKeyBox_PasswordChanged"/>
                    
                    <Rectangle Height="1" Fill="{ThemeResource SystemControlBackgroundBaseLowBrush}" Margin="0,24,0,24"/>
                    
                    <ToggleSwitch x:Name="GeminiToggle" Header="Use Gemini API" IsOn="False" Toggled="GeminiToggle_Toggled"/>
                    <PasswordBox x:Name="GeminiApiKeyBox" Header="Gemini API Key" PlaceholderText="AIza..." Width="239" HorizontalAlignment="Left" Margin="0,12,0,0" PasswordChanged="GeminiApiKeyBox_PasswordChanged"/>
                </StackPanel>

                <Rectangle Height="1" Fill="{ThemeResource SystemControlBackgroundBaseLowBrush}"/>

                <!-- About Section -->
                <StackPanel>
                    <TextBlock Text="About" 
                               Style="{StaticResource SubtitleTextBlockStyle}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12"/>
                    <TextBlock Text="FluentAI v1.0.0" FontWeight="SemiBold"/>
                    <TextBlock Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"><Run Foreground="White" Text="by Xiefn Yu"/></TextBlock>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
