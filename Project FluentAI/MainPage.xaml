<Page
    x:Class="Project_FluentAI.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Project_FluentAI"
    xmlns:models="using:Project_FluentAI.Models"
    xmlns:helpers="using:Project_FluentAI.Helpers"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom Title Bar / Drag Region -->
        <Grid x:Name="AppTitleBar" Background="Transparent" Height="32" VerticalAlignment="Top" Canvas.ZIndex="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftPaddingColumn" Width="0"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="RightPaddingColumn" Width="0"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="AppTitle" Text="FluentAI" VerticalAlignment="Center" Margin="12,0,0,0" Style="{StaticResource CaptionTextBlockStyle}" Visibility="Collapsed"/>
        </Grid>

        <NavigationView Grid.RowSpan="2" x:Name="NavView"
                        DisplayModeChanged="NavView_DisplayModeChanged"
                        IsSettingsVisible="True"
                        PaneDisplayMode="Left"
                        IsBackButtonVisible="Collapsed"
                        Header="FluentAI"
                        ItemInvoked="NavView_ItemInvoked"
                        ExpandedModeThresholdWidth="641"
                        Background="Transparent">
            <!-- Add top padding to the header to avoid overlap with title bar buttons -->
            <NavigationView.HeaderTemplate>
                <DataTemplate>
                    <Grid Margin="0,32,0,0">
                        <TextBlock Text="{Binding}" Style="{StaticResource TitleTextBlockStyle}"/>
                    </Grid>
                </DataTemplate>
            </NavigationView.HeaderTemplate>

            <!-- PaneCustomContent fills the area above the built-in Settings footer.
                 Row 3 is a star-height ScrollViewer so the chat list scrolls
                 independently and never pushes the Settings item off-screen. -->
            <NavigationView.PaneCustomContent>
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <!-- New Chat button -->
                        <RowDefinition Height="Auto"/>
                        <!-- Search box -->
                        <RowDefinition Height="Auto"/>
                        <!-- "Chats" section header -->
                        <RowDefinition Height="Auto"/>
                        <!-- Scrollable chat list -->
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- New Chat Button -->
                    <NavigationViewItem x:Name="NewChatButton"
                                        Icon="Add"
                                        Content="New Chat"
                                        Tapped="NewChatButton_Tapped"
                                        Margin="4,0,4,12"/>

                    <!-- Search Box -->
                    <AutoSuggestBox Grid.Row="1"
                                    x:Name="ChatSearchBox"
                                    PlaceholderText="Find a chat"
                                    QueryIcon="Find"
                                    Margin="16,0,16,32"
                                    Width="Auto"
                                    MaxWidth="268"
                                    HorizontalAlignment="Stretch"
                                    TextChanged="ChatSearchBox_TextChanged"/>

                    <!-- Chats Section Header -->
                    <TextBlock Grid.Row="2"
                               x:Name="ChatsHeader"
                               Text="Chats"
                               Style="{StaticResource BaseTextBlockStyle}"
                               FontWeight="SemiBold"
                               Margin="16,0,0,12"
                               FontSize="14"/>

                    <!-- Scrollable chat list.
                         The ScrollViewer clips the ListView so it never grows
                         beyond the available pane height. The NavigationView
                         built-in Settings item remains pinned at the bottom. -->
                    <ScrollViewer Grid.Row="3"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollMode="Auto">
                        <ListView x:Name="ChatListView"
                                  ItemsSource="{x:Bind ViewModel.Chats, Mode=OneWay}"
                                  SelectedItem="{x:Bind ViewModel.SelectedChat, Mode=TwoWay}"
                                  SelectionMode="Single"
                                  SelectionChanged="ChatListView_SelectionChanged">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:ChatItem">
                                    <Grid Background="Transparent" Padding="12,0">
                                        <Grid.ContextFlyout>
                                            <MenuFlyout>
                                                <MenuFlyoutItem Text="Rename"
                                                                Click="RenameChat_Click"
                                                                Icon="Edit"/>
                                                <MenuFlyoutItem Text="{x:Bind PinLabel, Mode=OneWay}"
                                                                Click="PinChat_Click"
                                                                Icon="Pin"/>
                                                <MenuFlyoutSeparator/>
                                                <MenuFlyoutItem Text="Delete"
                                                                Click="DeleteChat_Click"
                                                                Icon="Delete"/>
                                            </MenuFlyout>
                                        </Grid.ContextFlyout>

                                        <StackPanel Orientation="Horizontal" Padding="4,8">
                                            <!-- Small pin indicator visible only when chat is pinned -->
                                            <FontIcon Glyph="&#xE840;"
                                                      FontSize="11"
                                                      Margin="0,0,5,0"
                                                      Foreground="{ThemeResource SystemControlHighlightAccentBrush}"
                                                      Visibility="{x:Bind IsPinned, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            <FontIcon Glyph="&#xE8BD;"
                                                      FontSize="16"
                                                      Margin="0,0,12,0"
                                                      Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                            <TextBlock Text="{x:Bind Title, Mode=OneWay}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </ScrollViewer>
                </Grid>
            </NavigationView.PaneCustomContent>

            <NavigationView.Content>
                <Frame x:Name="ContentFrame"/>
            </NavigationView.Content>
        </NavigationView>
    </Grid>
</Page>
